<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fxml.AccountantMainController">

    <!-- TOP BAR – YOUR BEAUTIFUL DESIGN (UNCHANGED) -->
    <top>
        <VBox style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <HBox alignment="CENTER_LEFT" spacing="20">
                <Label style="-fx-text-fill: white; -fx-font-size: 22; -fx-font-weight: bold;" text="Mill House – Accountant" />

                <Region HBox.hgrow="ALWAYS" />

                <Label fx:id="welcomeLabel" style="-fx-text-fill: #ecf0f1; -fx-font-size: 16; -fx-font-weight: bold;" text="Welcome, Accountant" />

                <Button onAction="#handleLogout" style="-fx-background-color: #e74c3c;                                -fx-text-fill: white;                                -fx-font-weight: bold;                                -fx-padding: 8 25;                                -fx-background-radius: 30;                                -fx-cursor: hand;                                -fx-font-size: 14;" text="Logout" />
            </HBox>
        </VBox>
    </top>

    <!-- MAIN CONTENT — ONLY TABPANE WITH CLEAN INCLUDES -->
    <center>
        <TabPane style="-fx-font-family: 'Segoe UI';" tabClosingPolicy="UNAVAILABLE">

            <Tab text="Dashboard">
                <fx:include fx:id="dashboardTab" source="accountant/tabs/DashboardTab.fxml" />
            </Tab>

            <Tab text="Financial Records">
                <fx:include fx:id="financeTab" source="accountant/tabs/FinancialRecordsTab.fxml" />
            </Tab>

            <Tab text="Payment Processing">
                <fx:include fx:id="paymentTab" source="accountant/tabs/PaymentProcessingTab.fxml" />
            </Tab>

            <Tab text="Salary Records">
                <fx:include fx:id="salaryTab" source="accountant/tabs/SalaryRecordsTab.fxml" />
            </Tab>

        </TabPane>
    </center>
</BorderPane>
