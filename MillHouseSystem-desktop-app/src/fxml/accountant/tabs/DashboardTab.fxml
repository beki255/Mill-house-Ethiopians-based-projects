<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="25" style="-fx-padding: 30;" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="fxml.accountant.tabs.DashboardTabController">
    <Label fx:id="todaySummaryLabel"
           text="Today's Summary"
           style="-fx-font-size: 18; -fx-text-fill: #27ae60; -fx-font-weight: bold;"/>

    <Separator/>

    <HBox spacing="30" alignment="CENTER">
        <VBox style="-fx-background-color: #3498db; -fx-padding: 20; -fx-background-radius: 12; -fx-min-width: 220;">
            <Label text="Total Revenue Today" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
            <Label fx:id="todayRevenueLabel" text="ETB 0.00"
                   style="-fx-text-fill: white; -fx-font-size: 32; -fx-font-weight: bold;"/>
        </VBox>

        <VBox style="-fx-background-color: #e74c3c; -fx-padding: 20; -fx-background-radius: 12; -fx-min-width: 220;">
            <Label text="Total Expenses Today" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
            <Label fx:id="todayExpensesLabel" text="ETB 0.00"
                   style="-fx-text-fill: white; -fx-font-size: 32; -fx-font-weight: bold;"/>
        </VBox>

        <VBox style="-fx-background-color: #2ecc71; -fx-padding: 20; -fx-background-radius: 12; -fx-min-width: 220;">
            <Label text="Net Profit Today" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
            <Label fx:id="todayProfitLabel" text="ETB 0.00"
                   style="-fx-text-fill: white; -fx-font-size: 32; -fx-font-weight: bold;"/>
        </VBox>
    </HBox>
</VBox>