<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" style="-fx-padding: 20;" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="fxml.operator.tabs.OrdersTabController">
    
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Order Management" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="orderCountLabel" text="Total Orders: 0" 
               style="-fx-font-weight: bold; -fx-text-fill: #3498db;"/>
    </HBox>
    
    <Separator/>
    
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Search:"/>
        <TextField fx:id="searchField" promptText="Search by customer, grain, or ID..." prefWidth="300"/>
        <Label text="Status:"/>
        <ComboBox fx:id="statusFilterCombo" prefWidth="150"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="refreshButton" text="Refresh" onAction="#handleRefresh"
                style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
        <Button fx:id="assignMillButton" text="Assign to Mill" onAction="#handleAssignToMill"
                style="-fx-background-color: #f39c12; -fx-text-fill: white;"/>
        <Button fx:id="processOrderButton" text="Process Order" onAction="#handleProcessOrder"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </HBox>
    
    <TableView fx:id="ordersTable" prefHeight="400">
        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
    </TableView>
    
</VBox>