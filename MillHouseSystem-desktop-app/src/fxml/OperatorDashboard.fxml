<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="mainPane" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fxml.OperatorMainController">

   <top>
      <VBox spacing="10" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
         <HBox alignment="CENTER_LEFT" spacing="20">
            <Label style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;" text="Mill House - Operator " />
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#handleRefreshAll" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-min-width: 120;" text="Refresh Data" />
            <!-- ADD THIS LOGOUT BUTTON -->
            <Button onAction="#handleLogout" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-min-width: 80;" text="Logout" />
         </HBox>
      </VBox>
   </top>

   <center>
      <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE">
      <!-- Add this Tab to the TabPane in OperatorDashboard.fxml -->
      
         <Tab text="Transactions">
            <fx:include fx:id="transactionTab" source="operator/tabs/TransactionTab.fxml" />
         </Tab>
         <Tab text="Inventory">
            <fx:include fx:id="inventoryTab" source="operator/tabs/InventoryTab.fxml" />
         </Tab>
         <Tab text="Orders">
            <fx:include fx:id="ordersTab" source="operator/tabs/OrdersTab.fxml" />
         </Tab>
         <Tab text="Customers">
            <fx:include fx:id="customersTab" source="operator/tabs/CustomersTab.fxml" />
         </Tab>
         <Tab text="Monitoring">
            <fx:include fx:id="monitoringTab" source="operator/tabs/MonitoringTab.fxml" />
         </Tab>
         <Tab text="Delivery Management">
            <fx:include fx:id="deliveryTab" source="operator/tabs/DeliveryManagementTab.fxml" />
         </Tab>
           <Tab text="Electric Meter">
        <fx:include fx:id="electricMeterTab" source="operator/tabs/ElectricMeterTab.fxml" />
         </Tab>
      </TabPane>
   </center>
</BorderPane>
