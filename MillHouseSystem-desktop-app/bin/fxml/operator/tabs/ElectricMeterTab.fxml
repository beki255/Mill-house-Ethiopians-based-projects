<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true" xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="fxml.operator.tabs.ElectricMeterTabController">
    
    <VBox spacing="20" style="-fx-padding: 20;">
        
        <!-- Header -->
        <Label text="⚡ Electric Meter Management" 
               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        
        <!-- Daily Reading Section -->
        <VBox spacing="15" style="-fx-padding: 20; -fx-background-color: #e8f4fd; -fx-background-radius: 10;">
            <Label text="Daily Meter Reading" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2980b9;"/>
            
            <GridPane hgap="15" vgap="12">
                <columnConstraints>
                    <ColumnConstraints prefWidth="150"/>
                    <ColumnConstraints prefWidth="250"/>
                </columnConstraints>
                
                <Label text="Reading Date:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                <DatePicker fx:id="readingDatePicker" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                
                <Label text="Meter Reading (kWh):" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                <TextField fx:id="meterReadingField" GridPane.rowIndex="1" GridPane.columnIndex="1" promptText="Enter reading in kWh"/>
                
                <Label text="Recorded By:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                <TextField fx:id="recordedByField" GridPane.rowIndex="2" GridPane.columnIndex="1" promptText="Your name"/>
                
                <HBox spacing="15" GridPane.rowIndex="3" GridPane.columnIndex="0" GridPane.columnSpan="2">
                    <Button text="Submit Reading" onAction="#handleSubmitReading" 
                            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20;"/>
                    <Button text="Clear" onAction="#handleClearForm" 
                            style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-padding: 10 20;"/>
                </HBox>
            </GridPane>
        </VBox>
        
        <!-- Cost Settings Section -->
        <VBox spacing="15" style="-fx-padding: 20; -fx-background-color: #fff3cd; -fx-background-radius: 10;">
            <Label text="Electricity Cost Settings" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #856404;"/>
            
            <HBox spacing="20" alignment="CENTER_LEFT">
                <Label text="Cost per Unit (ETB):" style="-fx-font-weight: bold;"/>
                <TextField fx:id="costPerUnitField" prefWidth="150" text="5.00"/>
                <Button text="Update Cost" onAction="#handleUpdateCost" 
                        style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="currentCostLabel" text="Current: ETB 5.00 per kWh" 
                       style="-fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
            </HBox>
        </VBox>
        
        <!-- Recent Readings Table -->
        <VBox spacing="15">
            <Label text="Recent Meter Readings" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            
            <TableView fx:id="readingsTable" prefHeight="300">
                <columns>
                    <TableColumn text="Date" prefWidth="120"/>
                    <TableColumn text="Reading (kWh)" prefWidth="150"/>
                    <TableColumn text="Recorded By" prefWidth="150"/>
                    <TableColumn text="Time" prefWidth="150"/>
                </columns>
            </TableView>
            
            <HBox spacing="15">
                <Button text="Refresh Readings" onAction="#handleRefreshReadings" 
                        style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
                <Button text="Delete Selected" onAction="#handleDeleteReading" 
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
            </HBox>
        </VBox>
        
        <!-- Monthly Summary -->
        <VBox spacing="15" style="-fx-padding: 20; -fx-background-color: #d4edda; -fx-background-radius: 10;">
            <Label text="📊 Monthly Electricity Summary" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #155724;"/>
            
            <HBox spacing="30" alignment="CENTER">
                <VBox alignment="CENTER" spacing="5">
                    <Label text="This Month Usage" style="-fx-font-weight: bold;"/>
                    <Label fx:id="monthlyUsageLabel" text="0.00 kWh" 
                           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2980b9;"/>
                </VBox>
                
                <VBox alignment="CENTER" spacing="5">
                    <Label text="Estimated Cost" style="-fx-font-weight: bold;"/>
                    <Label fx:id="monthlyCostLabel" text="ETB 0.00" 
                           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                </VBox>
                
                <VBox alignment="CENTER" spacing="5">
                    <Label text="Avg. Daily Usage" style="-fx-font-weight: bold;"/>
                    <Label fx:id="avgDailyUsageLabel" text="0.00 kWh" 
                           style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>
        </VBox>
        
        <!-- Information Box -->
        <VBox spacing="8" style="-fx-padding: 15; -fx-background-color: #f8f9fa; -fx-border-color: #dee2e6; -fx-border-radius: 5;">
            <Label text="ℹ️ Instructions:" style="-fx-font-weight: bold; -fx-text-fill: #0c5460;"/>
            <Label text="1. Submit daily meter readings to track electricity consumption" wrapText="true"/>
            <Label text="2. Update electricity cost per unit as needed" wrapText="true"/>
            <Label text="3. System calculates monthly usage and estimated costs automatically" wrapText="true"/>
        </VBox>
        
    </VBox>
</ScrollPane>