<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="fxml.admin.tabs.SalaryProcessingTabController">
    <VBox spacing="20" style="-fx-padding: 25;">
        <!-- SECTION 1: STAFF SELECTION AND DETAILS -->
        <VBox spacing="15" style="-fx-padding: 20; -fx-background-color: #e8f4fd; -fx-background-radius: 10;">
            <Label text="Staff Selection  Details" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #2980b9;"/>
            
            <!-- Staff Selection -->
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Label text="Select Staff Member:" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="staffCombo" prefWidth="250" promptText="Select staff member"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Refresh Staff List" onAction="#handleRefreshStaffList"
                        style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;"/>
            </HBox>
            
            <!-- Staff Details Display (Read-only) -->
            <GridPane hgap="15" vgap="12" style="-fx-padding: 15; -fx-background-color: white; -fx-background-radius: 8;">
                <columnConstraints>
                    <ColumnConstraints prefWidth="150"/>
                    <ColumnConstraints prefWidth="250"/>
                    <ColumnConstraints prefWidth="150"/>
                    <ColumnConstraints prefWidth="250"/>
                </columnConstraints>
                
                <Label text="Staff Name:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                <TextField fx:id="staffNameField" editable="false" 
                          GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                
                <Label text="Role:" GridPane.rowIndex="0" GridPane.columnIndex="2" style="-fx-font-weight: bold;"/>
                <TextField fx:id="staffRoleField" editable="false" 
                          GridPane.rowIndex="0" GridPane.columnIndex="3"/>
                
                <Label text="Base Salary (ETB):" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                <TextField fx:id="baseSalaryField" editable="false" 
                          GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                
                <Label text="Monthly Period:" GridPane.rowIndex="1" GridPane.columnIndex="2" style="-fx-font-weight: bold;"/>
                <DatePicker fx:id="salaryMonthPicker" prefWidth="200" 
                           GridPane.rowIndex="1" GridPane.columnIndex="3"/>
            </GridPane>
        </VBox>
        
        <!-- SECTION 2: SALARY ADJUSTMENTS -->
        <VBox spacing="15" style="-fx-padding: 20; -fx-background-color: #fff3cd; -fx-background-radius: 10;">
            <Label text="Salary Adjustments" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #856404;"/>
            
            <HBox spacing="20" alignment="CENTER_LEFT">
                <VBox spacing="5">
                    <Label text="Bonus Amount (ETB):" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="bonusField" prefWidth="150" promptText="0.00"/>
                </VBox>
                
                <VBox spacing="5">
                    <Label text="Deductions (ETB):" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="deductionsField" prefWidth="150" promptText="0.00"/>
                </VBox>
                
                <VBox spacing="5">
                    <Label text="Net Salary (ETB):" style="-fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                    <Label fx:id="netSalaryLabel" text="0.00" 
                           style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                </VBox>
                
                <Region HBox.hgrow="ALWAYS"/>
                
                <Button text="Calculate Net Salary" onAction="#handleCalculateNetSalary"
                        style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
        
        <!-- SECTION 3: SALARY PROCESSING -->
        <VBox spacing="15" style="-fx-padding: 20; -fx-background-color: #d4edda; -fx-background-radius: 10;">
            <Label text="Process Salary" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #155724;"/>
            
            <HBox spacing="20" alignment="CENTER_LEFT">
                <VBox spacing="5">
                    <Label text="Payment Method:" style="-fx-font-weight: bold;"/>
                    <ComboBox fx:id="paymentMethodCombo" prefWidth="150"/>
                </VBox>
                
                <VBox spacing="5">
                    <Label text="Payment Status:" style="-fx-font-weight: bold;"/>
                    <ComboBox fx:id="statusCombo" prefWidth="150"/>
                </VBox>
                
                <Region HBox.hgrow="ALWAYS"/>
                
                <Button text="Process Salary" onAction="#handleProcessSalary"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 30;"/>
            </HBox>
        </VBox>
        
        <!-- SECTION 4: PROCESSED SALARIES TABLE -->
        <VBox spacing="15">
            <Label text="Recently Processed Salaries" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
            
            <TableView fx:id="processedSalariesTable" prefHeight="300">
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
            </TableView>
            
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Label fx:id="salarySummaryLabel" text="Total Processed: ETB 0.00" 
                       style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Refresh Processed Salaries" onAction="#handleRefreshProcessedSalaries"
                        style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
        
        <!-- Information Box -->
        <VBox spacing="8" style="-fx-padding: 15; -fx-background-color: #f8f9fa; -fx-border-color: #dee2e6; -fx-border-radius: 5;">
            <Label text="ℹ️ Salary Processing Guidelines:" style="-fx-font-weight: bold; -fx-text-fill: #0c5460;"/>
            <Label text="1. Select staff member to automatically fetch name, role, and base salary" 
                   style="-fx-text-fill: #0c5460;" wrapText="true"/>
            <Label text="2. System prevents duplicate salary processing for same staff and period" 
                   style="-fx-text-fill: #0c5460;" wrapText="true"/>
            <Label text="3. Only Admin users can process salaries" 
                   style="-fx-text-fill: #0c5460;" wrapText="true"/>
            <Label text="4. All salary records are stored in salary_payments table" 
                   style="-fx-text-fill: #0c5460;" wrapText="true"/>
        </VBox>
    </VBox>
</ScrollPane>