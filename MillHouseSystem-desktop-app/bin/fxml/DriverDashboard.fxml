<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fxml.DriverMainController">

    <!-- TOP BAR – YOUR ORIGINAL BEAUTIFUL DESIGN -->
    <top>
        <VBox style="-fx-background-color: #2c3e50; -fx-padding: 18; -fx-spacing: 15;">
            <HBox alignment="CENTER_LEFT" spacing="25">
                <Label style="-fx-text-fill: white; -fx-font-size: 26; -fx-font-weight: bold;" text="Mill House – Driver " />

                <Region HBox.hgrow="ALWAYS" />

                <Label fx:id="welcomeLabel" style="-fx-text-fill: #ecf0f1; -fx-font-size: 18; -fx-font-weight: bold;" text="Welcome, Driver" />

                <Button onAction="#handleRefreshAll" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 30; -fx-background-radius: 30;" text="Refresh All" />

                <Button onAction="#handleLogout" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 40; -fx-background-radius: 30;" text="Logout" />
            </HBox>
        </VBox>
    </top>

    <!-- MAIN CONTENT — CLEAN TABPANE WITH INCLUDES -->
    <center>
        <TabPane style="-fx-font-family: 'Segoe UI'; -fx-font-size: 14;" tabClosingPolicy="UNAVAILABLE">
            <Tab text="Dashboard">
                <fx:include fx:id="dashboardTab" source="driver/tabs/DashboardTab.fxml" />
            </Tab>
            <Tab text="Delivery Management">
                <fx:include fx:id="deliveryTab" source="driver/tabs/DeliveryManagementTab.fxml" />
            </Tab>
            <Tab text="Route Planning">
                <fx:include fx:id="routeTab" source="driver/tabs/RoutePlanningTab.fxml" />
            </Tab>
            <Tab text="Delivery History">
                <fx:include fx:id="historyTab" source="driver/tabs/DeliveryHistoryTab.fxml" />
            </Tab>
        </TabPane>
    </center>
</BorderPane>
