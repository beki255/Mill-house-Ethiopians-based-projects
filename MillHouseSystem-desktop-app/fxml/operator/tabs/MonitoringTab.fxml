<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" vbarPolicy="AS_NEEDED"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="fxml.operator.tabs.MonitoringTabController">
   <VBox spacing="15" style="-fx-padding: 20;">
      <Label text="Daily Monitoring Quality Control" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />

      <VBox spacing="10" style="-fx-padding: 15; -fx-background-color: #e8f4fd; -fx-background-radius: 5;">
         <Label text="Electricity Meter Reading" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #2980b9;" />
         <GridPane hgap="15" vgap="10" alignment="CENTER_LEFT">
            <Label text="Current Reading" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;" />
            <TextField fx:id="electricityReadingField" promptText="Enter reading" GridPane.rowIndex="0" GridPane.columnIndex="1" />
            <Label text="Date" GridPane.rowIndex="0" GridPane.columnIndex="2" style="-fx-font-weight: bold;" />
            <DatePicker fx:id="monitoringDatePicker" GridPane.rowIndex="0" GridPane.columnIndex="3" />
            <Button text="Save Reading" onAction="#handleElectricityReading" GridPane.rowIndex="1" GridPane.columnIndex="0"
                    style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;" />
         </GridPane>
         <Label fx:id="lastElectricityReadingLabel" text="Last reading: " style="-fx-text-fill: #7f8c8d;"/>
      </VBox>

      <Separator/>

      <VBox spacing="10" style="-fx-padding: 15; -fx-background-color: #f0f8ff; -fx-background-radius: 5;">
         <Label text="Grain Quality Assessment (Moisture Content)" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #27ae60;" />
         <GridPane hgap="15" vgap="10">
            <Label text="Grain Type" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;" />
            <ComboBox fx:id="moistureGrainTypeCombo" promptText="Select grain type" GridPane.rowIndex="0" GridPane.columnIndex="1" />
            <Label text="Moisture Content (%)" GridPane.rowIndex="0" GridPane.columnIndex="2" style="-fx-font-weight: bold;" />
            <TextField fx:id="moistureContentField" promptText="Enter %" GridPane.rowIndex="0" GridPane.columnIndex="3" />
            <Button text="Check Quality" onAction="#handleQualityCheck" GridPane.rowIndex="1" GridPane.columnIndex="0"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;" />
         </GridPane>
         <Label fx:id="qualityStatusLabel" text="Quality status will appear here"
                style="-fx-padding: 10; -fx-font-weight: bold;" />
      </VBox>
   </VBox>
</ScrollPane>